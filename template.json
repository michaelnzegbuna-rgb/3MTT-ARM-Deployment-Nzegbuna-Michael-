{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "virtualMachines_Mike_VM_name": {
            "defaultValue": "Mike-VM",
            "type": "String",
            "metadata": {
                "description": "Name of the Virtual Machine"
            }
        },
        "publicIPAddresses_Mike_VM_ip_name": {
            "defaultValue": "Mike-VM-ip",
            "type": "String",
            "metadata": {
                "description": "Name of the Public IP Address resource"
            }
        },
        "virtualNetworks_Mike_VM_vnet_name": {
            "defaultValue": "Mike-VM-vnet",
            "type": "String",
            "metadata": {
                "description": "Name of the Virtual Network"
            }
        },
        "networkInterfaces_mike_vm591_z1_name": {
            "defaultValue": "mike-vm591_z1",
            "type": "String",
            "metadata": {
                "description": "Name of the Network Interface Card (NIC)"
            }
        },
        "networkSecurityGroups_Mike_VM_nsg_name": {
            "defaultValue": "Mike-VM-nsg",
            "type": "String",
            "metadata": {
                "description": "Name of the Network Security Group"
            }
        },
        "location": {
            "type": "String",
            "defaultValue": "westeurope",
            "allowedValues": [
                "westeurope",
                "eastus",
                "eastus2",
                "westus2",
                "northeurope",
                "uksouth"
            ],
            "metadata": {
                "description": "Azure region where all resources will be deployed"
            }
        },
        "vmSize": {
            "type": "String",
            "defaultValue": "Standard_D2als_v7",
            "metadata": {
                "description": "Size/SKU of the Virtual Machine"
            }
        },
        "adminUsername": {
            "type": "String",
            "defaultValue": "azureuser",
            "metadata": {
                "description": "Administrator username for the Virtual Machine"
            }
        },
        "adminPassword": {
            "type": "SecureString",
            "metadata": {
                "description": "Administrator password for the Virtual Machine. Must be at least 12 characters and meet Azure complexity requirements."
            }
        },
        "allowedSSHSourceIP": {
            "type": "String",
            "defaultValue": "*",
            "metadata": {
                "description": "Source IP address or CIDR range allowed to SSH into the VM. Use '*' for any (not recommended for production). Example: '203.0.113.0/24'"
            }
        },
        "vnetAddressPrefix": {
            "type": "String",
            "defaultValue": "10.1.0.0/16",
            "metadata": {
                "description": "Address space for the Virtual Network (CIDR notation)"
            }
        },
        "subnetAddressPrefix": {
            "type": "String",
            "defaultValue": "10.1.0.0/24",
            "metadata": {
                "description": "Address prefix for the default subnet (CIDR notation)"
            }
        }
    },
    "variables": {
        "osDiskName": "[concat(parameters('virtualMachines_Mike_VM_name'), '_OsDisk_1')]",
        "subnetRef": "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('virtualNetworks_Mike_VM_vnet_name'), 'default')]",
        "nsgId": "[resourceId('Microsoft.Network/networkSecurityGroups', parameters('networkSecurityGroups_Mike_VM_nsg_name'))]",
        "publicIPId": "[resourceId('Microsoft.Network/publicIPAddresses', parameters('publicIPAddresses_Mike_VM_ip_name'))]",
        "nicId": "[resourceId('Microsoft.Network/networkInterfaces', parameters('networkInterfaces_mike_vm591_z1_name'))]"
    },
    "resources": [
        {
            "type": "Microsoft.Network/networkSecurityGroups",
            "apiVersion": "2025-05-01",
            "name": "[parameters('networkSecurityGroups_Mike_VM_nsg_name')]",
            "location": "[parameters('location')]",
            "properties": {
                "securityRules": [
                    {
                        "name": "SSH",
                        "properties": {
                            "description": "Allow SSH inbound from a specific source IP",
                            "protocol": "TCP",
                            "sourcePortRange": "*",
                            "destinationPortRange": "22",
                            "sourceAddressPrefix": "[parameters('allowedSSHSourceIP')]",
                            "destinationAddressPrefix": "*",
                            "access": "Allow",
                            "priority": 300,
                            "direction": "Inbound",
                            "sourcePortRanges": [],
                            "destinationPortRanges": [],
                            "sourceAddressPrefixes": [],
                            "destinationAddressPrefixes": []
                        }
                    },
                    {
                        "name": "DenyAllInbound",
                        "properties": {
                            "description": "Deny all other inbound traffic not explicitly allowed",
                            "protocol": "*",
                            "sourcePortRange": "*",
                            "destinationPortRange": "*",
                            "sourceAddressPrefix": "*",
                            "destinationAddressPrefix": "*",
                            "access": "Deny",
                            "priority": 4096,
                            "direction": "Inbound",
                            "sourcePortRanges": [],
                            "destinationPortRanges": [],
                            "sourceAddressPrefixes": [],
                            "destinationAddressPrefixes": []
                        }
                    }
                ]
            }
        },
        {
            "type": "Microsoft.Network/publicIPAddresses",
            "apiVersion": "2025-05-01",
            "name": "[parameters('publicIPAddresses_Mike_VM_ip_name')]",
            "location": "[parameters('location')]",
            "sku": {
                "name": "Standard",
                "tier": "Regional"
            },
            "zones": [
                "1"
            ],
            "properties": {
                "publicIPAddressVersion": "IPv4",
                "publicIPAllocationMethod": "Static",
                "idleTimeoutInMinutes": 4,
                "ipTags": [],
                "ddosSettings": {
                    "protectionMode": "VirtualNetworkInherited"
                }
            }
        },
        {
            "type": "Microsoft.Network/virtualNetworks",
            "apiVersion": "2025-05-01",
            "name": "[parameters('virtualNetworks_Mike_VM_vnet_name')]",
            "location": "[parameters('location')]",
            "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "[parameters('vnetAddressPrefix')]"
                    ]
                },
                "privateEndpointVNetPolicies": "Disabled",
                "subnets": [
                    {
                        "name": "default",
                        "properties": {
                            "addressPrefix": "[parameters('subnetAddressPrefix')]",
                            "delegations": [],
                            "privateEndpointNetworkPolicies": "Disabled",
                            "privateLinkServiceNetworkPolicies": "Enabled"
                        }
                    }
                ],
                "virtualNetworkPeerings": [],
                "enableDdosProtection": false
            }
        },
        {
            "type": "Microsoft.Network/virtualNetworks/subnets",
            "apiVersion": "2025-05-01",
            "name": "[concat(parameters('virtualNetworks_Mike_VM_vnet_name'), '/default')]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/virtualNetworks', parameters('virtualNetworks_Mike_VM_vnet_name'))]"
            ],
            "properties": {
                "addressPrefix": "[parameters('subnetAddressPrefix')]",
                "delegations": [],
                "privateEndpointNetworkPolicies": "Disabled",
                "privateLinkServiceNetworkPolicies": "Enabled"
            }
        },
        {
            "type": "Microsoft.Network/networkInterfaces",
            "apiVersion": "2025-05-01",
            "name": "[parameters('networkInterfaces_mike_vm591_z1_name')]",
            "location": "[parameters('location')]",
            "dependsOn": [
                "[variables('publicIPId')]",
                "[variables('subnetRef')]",
                "[variables('nsgId')]"
            ],
            "kind": "Regular",
            "properties": {
                "ipConfigurations": [
                    {
                        "name": "ipconfig1",
                        "properties": {
                            "privateIPAllocationMethod": "Dynamic",
                            "publicIPAddress": {
                                "id": "[variables('publicIPId')]",
                                "properties": {
                                    "deleteOption": "Detach"
                                }
                            },
                            "subnet": {
                                "id": "[variables('subnetRef')]"
                            },
                            "primary": true,
                            "privateIPAddressVersion": "IPv4"
                        }
                    }
                ],
                "dnsSettings": {
                    "dnsServers": []
                },
                "enableAcceleratedNetworking": true,
                "enableIPForwarding": false,
                "disableTcpStateTracking": false,
                "networkSecurityGroup": {
                    "id": "[variables('nsgId')]"
                },
                "nicType": "Standard",
                "auxiliaryMode": "None",
                "auxiliarySku": "None"
            }
        },
        {
            "type": "Microsoft.Compute/virtualMachines",
            "apiVersion": "2025-04-01",
            "name": "[parameters('virtualMachines_Mike_VM_name')]",
            "location": "[parameters('location')]",
            "dependsOn": [
                "[variables('nicId')]"
            ],
            "zones": [
                "1"
            ],
            "properties": {
                "hardwareProfile": {
                    "vmSize": "[parameters('vmSize')]"
                },
                "additionalCapabilities": {
                    "hibernationEnabled": false
                },
                "storageProfile": {
                    "imageReference": {
                        "publisher": "canonical",
                        "offer": "ubuntu-24_04-lts",
                        "sku": "server",
                        "version": "latest"
                    },
                    "osDisk": {
                        "osType": "Linux",
                        "name": "[variables('osDiskName')]",
                        "createOption": "FromImage",
                        "caching": "ReadWrite",
                        "deleteOption": "Delete"
                    },
                    "dataDisks": [],
                    "diskControllerType": "NVMe"
                },
                "osProfile": {
                    "computerName": "[parameters('virtualMachines_Mike_VM_name')]",
                    "adminUsername": "[parameters('adminUsername')]",
                    "adminPassword": "[parameters('adminPassword')]",
                    "linuxConfiguration": {
                        "disablePasswordAuthentication": false,
                        "provisionVMAgent": true,
                        "patchSettings": {
                            "patchMode": "ImageDefault",
                            "assessmentMode": "ImageDefault"
                        }
                    },
                    "secrets": [],
                    "allowExtensionOperations": true
                },
                "securityProfile": {
                    "uefiSettings": {
                        "secureBootEnabled": true,
                        "vTpmEnabled": true
                    },
                    "securityType": "TrustedLaunch"
                },
                "networkProfile": {
                    "networkInterfaces": [
                        {
                            "id": "[variables('nicId')]",
                            "properties": {
                                "deleteOption": "Detach"
                            }
                        }
                    ]
                },
                "diagnosticsProfile": {
                    "bootDiagnostics": {
                        "enabled": true
                    }
                }
            }
        }
    ],
    "outputs": {
        "vmName": {
            "type": "String",
            "value": "[parameters('virtualMachines_Mike_VM_name')]"
        },
        "vmResourceId": {
            "type": "String",
            "value": "[resourceId('Microsoft.Compute/virtualMachines', parameters('virtualMachines_Mike_VM_name'))]"
        },
        "publicIPAddress": {
            "type": "String",
            "value": "[reference(variables('publicIPId')).ipAddress]"
        },
        "publicIPResourceId": {
            "type": "String",
            "value": "[variables('publicIPId')]"
        },
        "privateIPAddress": {
            "type": "String",
            "value": "[reference(variables('nicId')).ipConfigurations[0].properties.privateIPAddress]"
        },
        "sshCommand": {
            "type": "String",
            "value": "[concat('ssh ', parameters('adminUsername'), '@', reference(variables('publicIPId')).ipAddress)]"
        },
        "vnetResourceId": {
            "type": "String",
            "value": "[resourceId('Microsoft.Network/virtualNetworks', parameters('virtualNetworks_Mike_VM_vnet_name'))]"
        },
        "nsgResourceId": {
            "type": "String",
            "value": "[variables('nsgId')]"
        },
        "deploymentLocation": {
            "type": "String",
            "value": "[parameters('location')]"
        }
    }
}
